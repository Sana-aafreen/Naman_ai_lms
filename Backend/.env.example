# ─────────────────────────────────────────────────────────────────────────────
# NamanDarshan LMS - Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Configuration ──────────────────────────────────────────────────────
# For local MongoDB (default):
MONGODB_URL=mongodb://localhost:27017

# For MongoDB Atlas (cloud):
# MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

MONGODB_DB=naman_lms
MONGODB_TIMEOUT=10000

# ── Google APIs ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# ── Google Sheets ──────────────────────────────────────────────────────────────
GOOGLE_SHEETS_API=your-sheets-api-credentials-here

# ── Database (Legacy - for backward compatibility) ───────────────────────────
# DATABASE_URL=postgresql://user:password@localhost/dbname
SQLITE_DB_PATH=./data/courses.db

# ── LMS Settings ───────────────────────────────────────────────────────────────
LMS_PASS_THRESHOLD=70
GEMINI_MODEL=gemini-1.5-flash
