{
  "version": 2,
  "name": "namandarshan-lms",
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://namandarshan-backend.onrender.com/api/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/Frontend/index.html" }
  ]
}
